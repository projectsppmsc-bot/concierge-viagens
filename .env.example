# URL pública do app
NEXT_PUBLIC_APP_URL=

# ─────────────────────────────────────────────
# Provider de voos: "mock" | "travelpayouts" | "amadeus"
# ─────────────────────────────────────────────
NEXT_PUBLIC_FLIGHT_PROVIDER=mock

# ─────────────────────────────────────────────
# Travelpayouts — afiliado Aviasales
# Marker: seu ID no painel (ex: 734848)
# NEXT_PUBLIC_ = visível no browser (só o marker, não o token)
# ─────────────────────────────────────────────
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=
TRAVELPAYOUTS_TOKEN=

# ─────────────────────────────────────────────
# Amadeus — DESCONTINUADO em 17/07/2026
# ─────────────────────────────────────────────
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Supabase (futuro)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
